{
  "name": "prd-gen",
  "version": "0.1.0",
  "description": "Single-story-at-a-time PRD review tool",
  "type": "module",
  "bin": {
    "prd-gen": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["prd", "cli", "review"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0"
  }
}
